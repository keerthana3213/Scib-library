# Npm parameters
# Node versions available: 12.22.12, 14.21.3, 16.20.2, 18.18.2, 18.20.2, 20.14.0
NODE_VERSION="20.14.0"
NPM_APPLICATION_DIST_DIRECTORY='dist/'
NPM_APPLICATION_DIST_CONTENT="*"
NPM_CONFIGURATION_DIST_DIRECTORY="./"
NPM_CONFIGURATION_DIST_CONTENT="conf.d/"
NPM_RUN_INSTALL_COMMAND="npm ci"
URBANCODE_APPLICATION="cib-digital-platform"
NPM_RUN_TEST_COMMAND="npm run ci-test"
FORTIFY_PROJECT="cib-dpemp-uikit"
SONAR_PROJECT_KEY="cib-dpemp-uikit"
NPM_LIBRARY_DIST_DIRECTORY="./"
NPM_PUBLISH_ARTIFACT=true
NPM_SONAR_PROPERTIES="-Dsonar.exclusions=node_modules/**,src/playgrounds/**,src/assets/**,src/docs/**,src/flame/**,src/scss/**,src/themes/**,src/components/cdk/**,src/components/ecmv/**,src/components/ui/**,src/shared/models.ts,src/utils/public_api.ts,src/angular-proxy.ts,src/externals.ts,src/index.ts,**.model.ts,**.config,**config.ts,**.stories.tsx,**.scss,**.eot,**.ttf,**.woff,**.woff2,**.spec.ts,**.spec.tsx,**.js,**.json -Dsonar.coverage.exclusions=node_modules/**,src/playgrounds/**,src/assets/**,src/docs/**,src/flame/**,src/scss/**,src/themes/**,src/components/cdk/**,src/components/ecmv/**,src/components/ui/**,src/shared/models.ts,src/utils/public_api.ts,src/angular-proxy.ts,src/externals.ts,src/index.ts,**.model.ts,**.config,**config.ts,**.stories.tsx,**.scss,**.eot,**.ttf,**.woff,**.woff2,**.spec.ts,**.spec.tsx,**.js,**.json -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info -Dsonar.test.inclusions=src/**/*.spec.ts,src/**/*.test.ts"
