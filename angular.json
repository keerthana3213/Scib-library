{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"angular-lib": {
			"projectType": "library",
			"root": ".angular-lib",
			"sourceRoot": ".angular-lib/src",
			"prefix": "lib",
			"architect": {
				"build": {
					"builder": "@angular-devkit/build-angular:ng-packagr",
					"options": {
						"project": ".angular-lib/ng-package.json"
					},
					"configurations": {
						"production": {
							"tsConfig": ".angular-lib/tsconfig.lib.prod.json"
						},
						"development": {
							"tsConfig": ".angular-lib/tsconfig.lib.json"
						}
					},
					"defaultConfiguration": "production"
				}
			}
		}
	}
}
