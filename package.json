{
  "name": "@scib/ui-kit",
  "version": "3.6.1-SNAPSHOT",
  "description": "Digital Platform Design System",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/scib-ui-kit/scib-ui-kit.esm.js",
  "repository": {
    "type": "git",
    "url": "https://github.alm.europe.cloudcenter.corp/cib-digital-platform/stencil-ui-kit.git"
  },
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "start": "cross-env TYPE_BUILDER=isolated-component-build npm run generate",
    "start:servers": "npm run generator:docs && concurrently -n storybook,stencil,proxy -c \"bgMagenta.bold,bgBlue.bold,bgCyan.bold\" \"npm:start:storybook\" \"npm:start:stencil\" \"npm:start:proxy\"",
    "start:proxy": "wait-on http://0.0.0.0:4301 && wait-on http://0.0.0.0:4302 && cross-env NODE_ENV=development node ./.storybook/proxy.js",
    "start:stencil": "cross-env NODE_ENV=development stencil build --dev --watch --docs --serve",
    "start:storybook": "storybook dev --no-open -p 4301",
    "build": "npx rimraf dist && npx rimraf angular && npx rimraf react && run-s generator:docs build:wrapper-folders build:stencil build:storybook build:angular-lib build:react-lib",
    "build:wrapper-folders": "shx mkdir -p angular && shx mkdir -p react",
    "build:angular-lib": "ng build angular-lib --configuration production && rm -f ./angular/.npmignore && npx cpx \".angular-lib/src/lib/**/*\" ./dist/angular",
    "build:react-lib": "cd .react-lib && npm run build && cd ..",
    "build:stencil": "cross-env NODE_ENV=production NODE_OPTIONS=--max-old-space-size=3072 stencil build --ci --verbose --prod --docs && npm run generator:wrappers && node .ci/fix-asset-path.js",
    "build:storybook": "storybook build --quiet -o ./dist/storybook && node .ci/copy-statics.js",
    "generator:docs": "run-s generator:fonts generator:images generator:playgrounds generator:themes generator:custom-props",
    "generator:fonts": "node .storybook/webfonts_old && node .storybook/webfonts && webfont src/assets/icons/*.svg --config ./webfonts.js && node .ci/fonts.js",
    "generator:custom-props": "node .ci/custom-props.js",
    "generator:fix-icons": "node .ci/fix-icons.js",
    "generator:catalog-components": "node .ci/catalog-components.js",
    "generator:images": "node .storybook/webimages",
    "generator:playgrounds": "node .storybook/playgrounds",
    "generator:themes": "node .ci/themes.js",
    "generator:wrappers": "node .ci/angular-module.js",
    "generate": "cd .generators && plop",
    "test:watch": "stencil test --spec --no-build --watchAll",
    "test:watch:coverage": "stencil test --spec --no-build --coverage --watchAll",
    "test": "stencil test --spec --no-build --coverage --ci --workerThreads",
    "ci-test": "npm run test"
  },
  "dependencies": {
    "@material/card": "^13.0.0",
    "@material/checkbox": "^13.0.0",
    "@material/chips": "^13.0.0",
    "@material/circular-progress": "^13.0.0",
    "@material/dialog": "^13.0.0",
    "@material/drawer": "^13.0.0",
    "@material/form-field": "^13.0.0",
    "@material/linear-progress": "^13.0.0",
    "@material/menu": "^13.0.0",
    "@material/menu-surface": "^13.0.0",
    "@material/radio": "^13.0.0",
    "@material/slider": "^13.0.0",
    "@material/snackbar": "^13.0.0",
    "@material/switch": "^13.0.0",
    "@material/tab-bar": "^13.0.0",
    "@material/textfield": "^13.0.0",
    "@noble/hashes": "^1.8.0",
    "@polymer/polymer": "~3.4.1",
    "@shopify/draggable": "~1.0.0-beta.10",
    "@stencil/core": "4.17.2",
    "@stencil/react-output-target": "^0.8.2",
    "@vaadin/vaadin-dialog": "~2.4.5",
    "air-datepicker": "^3.5.0",
    "autonumeric": "^4.10.0",
    "blueprint-css": "^3.1.3",
    "i18n-iso-countries": "^7.7.0",
    "libphonenumber-js": "^1.10.51",
    "lodash": "^4.17.21",
    "lottie-web": "^5.12.2",
    "luxon": "^3.4.4",
    "numeral": "^2.0.6",
    "progressbar.js": "^1.1.1",
    "quill": "~1.3.7",
    "resize-observer-polyfill": "^1.5.1",
    "rxjs": "^7.8.1",
    "sass-rem": "^3.0.0",
    "scrollable-component": "^1.2.1",
    "smoothscroll-polyfill": "~0.4.4",
    "sortablejs": "^1.15.0",
    "stencil-click-outside": "^1.8.0",
    "tabulator-tables": "~6.2.0",
    "tiny-slider": "^2.9.4",
    "tui-pagination": "^3.4.1",
    "uuid": "^9.0.1"
},
"devDependencies": {
    "@angular-devkit/build-angular": "^18.2.19",
    "@angular/cli": "^18.2.19",
    "@angular/common": "^18.2.13",
    "@angular/compiler-cli": "^18.2.13",
    "@angular/core": "^18.2.13",
    "@angular/forms": "^18.2.13",
    "@angular/platform-browser": "^18.2.13",
    "@angular/platform-browser-dynamic": "^18.2.13",
    "@babel/core": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@stencil/angular-output-target": "^0.10.2",
    "@stencil/sass": "^3.0.7",
    "@storybook/addon-actions": "^7.5.3",
    "@storybook/addon-essentials": "^7.5.3",
    "@storybook/addon-interactions": "^7.5.3",
    "@storybook/addon-links": "^7.5.3",
    "@storybook/blocks": "^7.5.3",
    "@storybook/builder-vite": "^7.5.3",
    "@storybook/react": "^7.5.3",
    "@storybook/react-vite": "^7.5.3",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.14.202",
    "@types/luxon": "^3.3.5",
    "@types/node": "^20.17.43",
    "ag-grid-community": "~23.2.1",
    "babel-jest": "^29.7.0",
    "concurrently": "^8.2.2",
    "cpx": "^1.5.0",
    "cross-env": "^7.0.3",
    "dom-slot-assign": "^0.1.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fast-glob": "^3.3.2",
    "http-proxy-middleware": "^2.0.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jsonfile": "^6.1.0",
    "ng-packagr": "^18.2.0",
    "node-fetch": "^2.7.0",
    "npm-run-all": "^4.1.5",
    "oslllo-svg-fixer": "^3.0.0",
    "plop": "^3.1.2",
    "prettier": "^2.8.8",
    "pretty-quick": "^3.1.3",
    "react": "^18.2.0",
    "react-custom-events-hooks": "^0.0.0",
    "react-dom": "^18.2.0",
    "react-syntax-highlighter": "^15.5.0",
    "replace-in-file": "^7.0.2",
    "rimraf": "^5.0.5",
    "sass": "~1.63.6",
    "sass-import-modules": "~8.0.0",
    "shelljs": "^0.8.5",
    "shx": "^0.4.0",
    "storybook": "^7.5.3",
    "storybook-addon-themes": "^6.1.0",
    "storybook-dark-mode": "^3.0.1",
    "tailwindcss": "^3.3.5",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~5.5.2",
    "upath": "^2.0.1",
    "vanilla-masker": "^1.2.0",
    "wait-on": "^7.2.0",
    "webfont": "^11.2.26",
    "workbox-build": "^6.6.1",
    "xlsx": "^0.18.5"
  },
  "files": [
    "dist",
    "angular",
    "react"
  ],
  "customConfig": {
    "storybook": {
      "dir": "dist/storybook",
      "port": 4301
    },
    "stencil": {
      "dir": "dist/scib-ui-kit",
      "port": 4302
    }
  },
  "engines": {
    "node": ">=16.14.2",
    "npm": ">=8.5.0"
  },
  "exports": {
    "./dist/*": "./dist/*",
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "es2015": "./dist/esm/index.mjs",
      "es2017": "./dist/esm/index.mjs",
      "es2022": "./dist/esm/index.mjs",
      "esm": "./dist/esm/index.mjs",
      "default": "./dist/index.js"
    },
    "./angular": {
      "types": "./angular/index.d.ts",
      "esm": "./angular/esm2022/scib-ui-kit-angular.mjs",
      "import": "./angular/fesm2022/scib-ui-kit-angular.mjs",
      "esm2022": "./angular/esm2022/scib-ui-kit-angular.mjs",
      "default": "./angular/fesm2022/scib-ui-kit-angular.mjs"
    },
    "./react": {
      "esm": "./react/index.js",
      "import": "./react/index.js",
      "esm2022": "./react/index.js",
      "default": "./react/index.js",
      "types": "./react/index.d.ts"
    }
  }
}
